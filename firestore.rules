rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function userId() { return request.auth.uid; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Helper: Check if user is a member or if it's a global room
    function canAccessRoom(roomId) {
      return exists(/databases/$(database)/documents/rooms/$(roomId)) && (
        get(/databases/$(database)/documents/rooms/$(roomId)).data.memberIds.hasAny([userId()]) || 
        get(/databases/$(database)/documents/rooms/$(roomId)).data.get('isGlobal', false) == true
      );
    }

    // --- USERS COLLECTION ---
    match /users/{uid} {
      function isValidUser(data) {
        return data.userId == uid &&
               data.email is string && data.email.size() <= 256 &&
               data.displayName is string && data.displayName.size() <= 100 &&
               (!('photoURL' in data) || data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 2048)) &&
               data.tier in ['Royal', 'Citizen'] &&
               data.createdAt == request.time;
      }

      // Users can only read and manage their own profile
      allow get: if isSignedIn() && userId() == uid;
      allow list: if false; 
      allow create: if isSignedIn() && userId() == uid && isValidUser(incoming());
      allow update: if isSignedIn() && userId() == uid && 
                      isValidUser(incoming()) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'tier']);
    }

    // --- WALLETS COLLECTION ---
    match /wallets/{uid} {
      function isValidWallet(data) {
        return data.userId == uid &&
               data.balance is int && data.balance >= 0 &&
               data.updatedAt == request.time;
      }

      allow get: if isSignedIn() && userId() == uid;
      allow create: if isSignedIn() && userId() == uid && isValidWallet(incoming());
      allow update: if isSignedIn() && userId() == uid && 
                      isValidWallet(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'updatedAt']);
    }

    // --- ROOMS COLLECTION ---
    match /rooms/{roomId} {
      function isValidRoom(data) {
        return data.name is string && data.name.size() <= 100 &&
               data.isGroup is bool &&
               (!('avatarUrl' in data) || data.avatarUrl == null || (data.avatarUrl is string && data.avatarUrl.size() <= 2048)) &&
               (!('isGlobal' in data) || data.isGlobal is bool);
      }

      allow get: if isSignedIn() && (existing().memberIds.hasAny([userId()]) || existing().get('isGlobal', false) == true);
      allow list: if isSignedIn() && (resource.data.memberIds.hasAny([userId()]) || resource.data.get('isGlobal', false) == true);

      allow create: if isSignedIn() && isValidRoom(incoming());
      
      allow update: if isSignedIn() && (
        (existing().memberIds.hasAny([userId()]) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatarUrl', 'lastMessage', 'lastMessageTime', 'unreadCount'])) ||
        (existing().get('isGlobal', false) == true && incoming().diff(existing()).affectedKeys().hasOnly(['memberIds']) && incoming().memberIds.hasAll(existing().memberIds.concat([userId()])))
      );

      // --- MEMBERS SUBCOLLECTION ---
      match /members/{memberId} {
        allow read: if isSignedIn() && canAccessRoom(roomId);
        
        allow create: if isSignedIn() && (
          (memberId == userId()) ||
          (exists(/databases/$(database)/documents/rooms/$(roomId)/members/$(userId())) && get(/databases/$(database)/documents/rooms/$(roomId)/members/$(userId())).data.role in ['Owner', 'Admin'])
        );

        allow delete: if isSignedIn() && (
          memberId == userId() || 
          (exists(/databases/$(database)/documents/rooms/$(roomId)/members/$(userId())) && get(/databases/$(database)/documents/rooms/$(roomId)/members/$(userId())).data.role in ['Owner', 'Admin'])
        );
      }

      // --- MESSAGES SUBCOLLECTION ---
      match /messages/{messageId} {
        function isValidMessage(data) {
          return data.senderId == userId() &&
                 data.senderName is string && data.senderName.size() <= 100 &&
                 (!('content' in data) || (data.content is string && data.content.size() <= 5000)) &&
                 (!('fileUrl' in data) || (data.fileUrl is string && data.fileUrl.size() <= 2048)) &&
                 data.fileType in ['text', 'image', 'video', 'file'] &&
                 data.timestamp == request.time;
        }

        allow read: if isSignedIn() && canAccessRoom(roomId);
        allow create: if isSignedIn() && canAccessRoom(roomId) && isValidMessage(incoming());
        allow update: if isSignedIn() && canAccessRoom(roomId) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['readBy']) &&
                       incoming().readBy.hasAll(existing().get('readBy', []).concat([userId()]));
        allow delete: if isSignedIn() && canAccessRoom(roomId) && (
          existing().senderId == userId() || 
          existing().get('burnAfter', null) != null ||
          (exists(/databases/$(database)/documents/rooms/$(roomId)/members/$(userId())) && get(/databases/$(database)/documents/rooms/$(roomId)/members/$(userId())).data.role in ['Owner', 'Admin'])
        );
      }
    }
  }
}
