rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function userId() { return request.auth.uid; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Helper: Check if user is a member of a room
    function isMember(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)).data.memberIds.hasAny([userId()]);
    }

    // --- USERS COLLECTION ---
    match /users/{uid} {
      function isValidUser(data) {
        return data.userId == uid &&
               data.email is string && data.email.size() <= 256 &&
               data.displayName is string && data.displayName.size() <= 100 &&
               (!('photoURL' in data) || data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 2048)) &&
               data.tier in ['Royal', 'Citizen'] &&
               data.createdAt == request.time;
      }

      // Users can only read and manage their own profile
      allow get: if isVerified() && userId() == uid;
      allow list: if false; // No blanket listing of users
      allow create: if isVerified() && userId() == uid && isValidUser(incoming());
      allow update: if isVerified() && userId() == uid && 
                      isValidUser(incoming()) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'tier']);
    }

    // --- WALLETS COLLECTION ---
    match /wallets/{uid} {
      function isValidWallet(data) {
        return data.userId == uid &&
               data.balance is int && data.balance >= 0 &&
               data.updatedAt == request.time;
      }

      allow get: if isVerified() && userId() == uid;
      allow create: if isVerified() && userId() == uid && isValidWallet(incoming());
      allow update: if isVerified() && userId() == uid && 
                      isValidWallet(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'updatedAt']);
    }

    // --- ROOMS COLLECTION ---
    match /rooms/{roomId} {
      function isValidRoom(data) {
        return data.name is string && data.name.size() <= 100 &&
               data.isGroup is bool &&
               (!('avatarUrl' in data) || data.avatarUrl == null || (data.avatarUrl is string && data.avatarUrl.size() <= 2048));
      }

      // A room is readable if the user is a member
      allow get: if isVerified() && existing().memberIds.hasAny([userId()]);
      allow list: if isVerified() && resource.data.memberIds.hasAny([userId()]);

      // Creation: must also create membership in the same batch (handled by logic)
      allow create: if isVerified() && isValidRoom(incoming());
      
      allow update: if isVerified() && existing().memberIds.hasAny([userId()]) && (
        // Only allow updating metadata
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatarUrl', 'lastMessage', 'lastMessageTime'])
      );

      // --- MEMBERS SUBCOLLECTION ---
      match /members/{memberId} {
        allow read: if isVerified() && isMember(roomId);
        
        allow create: if isVerified() && (
          (memberId == userId() && incoming().role == 'Owner') ||
          (get(/databases/$(database)/documents/rooms/$(roomId)/members/$(userId())).data.role in ['Owner', 'Admin'])
        );

        allow delete: if isVerified() && (
          memberId == userId() || 
          (get(/databases/$(database)/documents/rooms/$(roomId)/members/$(userId())).data.role in ['Owner', 'Admin'])
        );
      }

      // --- MESSAGES SUBCOLLECTION ---
      match /messages/{messageId} {
        function isValidMessage(data) {
          return data.senderId == userId() &&
                 data.senderName is string && data.senderName.size() <= 100 &&
                 (!('content' in data) || (data.content is string && data.content.size() <= 5000)) &&
                 (!('fileUrl' in data) || (data.fileUrl is string && data.fileUrl.size() <= 2048)) &&
                 data.fileType in ['text', 'image', 'video', 'file'] &&
                 data.timestamp == request.time;
        }

        allow read: if isVerified() && isMember(roomId);
        allow create: if isVerified() && isMember(roomId) && isValidMessage(incoming());
        allow delete: if isVerified() && (
          existing().senderId == userId() || 
          (get(/databases/$(database)/documents/rooms/$(roomId)/members/$(userId())).data.role in ['Owner', 'Admin'])
        );
      }
    }
  }
}
